{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Collector": {
    "PollSeconds": 60,
    "RunOnceAndExit": true,
    "SqlitePath": "data/marketdata.db",
    "Sources": {
      "Demo": false,
      "BinanceSpot": true,
      "BinanceKlines": true,
      "CoinGecko": false
    },
    "CoinGecko": {
      "BaseUrl": "https://api.coingecko.com/api/v3",
      "VsCurrency": "usd",
      "Pages": 1,
      "PerPage": 250,
      "DemoApiKey": ""
    },
    "BinanceSpot": {
      "BaseUrl": "https://data-api.binance.vision"
    },
    "BinanceKlines": {
      "QuoteAssets": ["USDT", "USDC"],
      "Intervals": ["1m", "5m", "15m"],
      "Limit": 120,
      "MaxSymbols": 60,
      "MinQuoteVolume24h": 500000,
      "MaxSpreadBps": 50,
      "DelayMsBetweenRequests": 150
    }
  }
}