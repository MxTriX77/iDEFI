{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  "Collector": {
    "PollSeconds": 60,
    "RunOnceAndExit": true,
    "SqlitePath": "data/marketdata.db",

    "Sources": {
      "Demo": false,
      "BinanceSpot": true,
      "CoinGecko": false
    },

    "CoinGecko": {
      "BaseUrl": "https://api.coingecko.com/api/v3",
      "VsCurrency": "usd",
      "Pages": 1,
      "PerPage": 250,
      "DemoApiKey": ""
    },

    "BinanceSpot": {
      "BaseUrl": "https://data-api.binance.vision"
    }
  }
}